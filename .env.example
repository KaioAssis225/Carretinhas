# Copie para .env e ajuste. NUNCA commite o .env real.

# --- Banco (Docker Compose de desenvolvimento) ---
POSTGRES_USER=assiscarretas
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=assiscarretas

# --- Backend ---
ASSISCARRETAS_ENVIRONMENT=local
ASSISCARRETAS_DEBUG=true
ASSISCARRETAS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=postgresql+psycopg://assiscarretas:troque-esta-senha@localhost:5432/assiscarretas

# --- Frontend ---
# Opcional. Sem esta variável, o frontend usa o mesmo hostname da página na porta 8000.
# VITE_API_URL=http://localhost:8000
